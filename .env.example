# PostgreSQL (Prisma) — obligatoire. Si vous aviez encore DATABASE=postgres://..., copiez-la ici sous DATABASE_URL.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/trainpredict
# Même base, connexion directe (sans Accelerate). Obligatoire si DATABASE_URL est prisma+postgres://… et que Assistant.embeddedYears dépasse la limite de taille des réponses Accelerate (~5 Mo).
# DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/trainpredict
APP_URL=http://localhost:3000
SERVER_URL=http://localhost:5000
PORT=5000
SECRET_KEY=

# Resend (https://resend.com) — domaine expéditeur vérifié obligatoire en prod
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM="TrainPredict <onboarding@votredomaine.com>"
# Optionnel :
# EMAIL_REPLY_TO=contact@trainpreddict.fr
